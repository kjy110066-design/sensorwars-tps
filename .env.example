# ── 클라우드(Railway) 배포 시 설정값 ──────────────────────────
# Railway 대시보드 > Variables 에 아래 값들을 입력하세요.

# 시뮬레이션 모드 (클라우드에서는 반드시 true)
SIM_MODE=true

# 서버 포트 (Railway가 자동 할당하므로 보통 설정 불필요)
# PORT=3000

# ── 로컬 실행 시 설정값 ──────────────────────────────────────
# .env 파일을 복사해서 아래처럼 수정하세요.

# SIM_MODE=false
# PORT=3000
# SERIAL_PORT_A=COM8
# SERIAL_PORT_B=COM4
